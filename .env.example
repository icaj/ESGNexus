# Kaggle — necessário para baixar o dataset ESG automaticamente no primeiro treino
# Obtenha em: https://www.kaggle.com/settings → API → Create New Token
# Se data/raw/data.csv já existir no host, estas variáveis são ignoradas.
KAGGLE_USERNAME=seu_usuario_kaggle
KAGGLE_KEY=sua_chave_api_kaggle

# NeonDB (PostgreSQL gerenciado)
DATABASE_URL=postgresql+psycopg://neondb_owner:npg_oQ4iTnNEqI3x@ep-fancy-art-apt303j2-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

SEGREDO_JWT=altere-este-segredo-em-producao
ALGORITMO_JWT=HS256
MINUTOS_EXPIRACAO_TOKEN=480
MLFLOW_TRACKING_URI=http://35.212.103.210:5000
MLFLOW_EXPERIMENTO=esg-nexus-fornecedores
ESG_NEXUS_API_URL=http://localhost:8000

# Administrador padrão da aplicação — criado automaticamente no primeiro startup
# Altere antes de usar em produção
USUARIO_ADMIN_EMAIL=admin@esgnexus.example
USUARIO_ADMIN_SENHA=admin123
USUARIO_ADMIN_NOME=Administrador ESG Nexus

# Conta de serviço usada pelo Airflow para autenticar no POST /treinar
# Criada automaticamente no startup da API se ESG_ADMIN_EMAIL e ESG_ADMIN_SENHA
# estiverem definidos. Deve ter perfil administrador ou cientista_dados.
ESG_ADMIN_EMAIL=admin@esg.example
ESG_ADMIN_SENHA=admin@ESG2026!
